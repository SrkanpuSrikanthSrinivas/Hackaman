{
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "dist",
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/register/(.*)",
      "destination": "/index.html"
    },
    {
      "source": "/admin",
      "destination": "/index.html"
    },
    {
      "source": "/admin/(.*)",
      "destination": "/index.html"
    },
    {
      "source": "/project/(.*)",
      "destination": "/index.html"
    },
    {
      "source": "/portal/(.*)",
      "destination": "/index.html"
    },
    {
      "source": "/demo",
      "destination": "/index.html"
    },
    {
      "source": "/reset-password",
      "destination": "/index.html"
    },
    {
      "source": "/forgot-password",
      "destination": "/index.html"
    },
    {
      "source": "/join/(.*)",
      "destination": "/index.html"
    },
    {
      "source": "/projects/(.*)",
      "destination": "/index.html"
    },
    {
      "source": "/u/(.*)",
      "destination": "/index.html"
    },
    {
      "source": "/winners",
      "destination": "/index.html"
    },
    {
      "source": "/hackathons",
      "destination": "/index.html"
    }
  ]
}