{
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "dist",
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/register/(.*)",
      "destination": "/index.html"
    },
    {
      "source": "/admin",
      "destination": "/index.html"
    },
    {
      "source": "/admin/(.*)",
      "destination": "/index.html"
    },
    {
      "source": "/project/(.*)",
      "destination": "/index.html"
    },
    {
      "source": "/portal/(.*)",
      "destination": "/index.html"
    },
    {
      "source": "/hackathons",
      "destination": "/index.html"
    }
  ]
}